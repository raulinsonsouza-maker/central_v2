# Copie para /etc/nginx/sites-available/central-inout
# ln -s /etc/nginx/sites-available/central-inout /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx   # reload, NÃO restart
# sudo certbot --nginx -d seu-dominio.com.br
#
# Não altere configs de outros sites. Ajuste a porta abaixo se PORT no .env ≠ 5000.

upstream central_inout {
    server 127.0.0.1:5000;
    keepalive 64;
}

server {
    listen 80;
    server_name seu-dominio.com.br;

    location / {
        proxy_pass http://central_inout;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 300s;
    }
}
