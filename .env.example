# Ambiente (development | production)
NODE_ENV=development

# Porta do app em produção (PM2/Next). Mude se 5000 já estiver em uso na VPS.
# PORT=5000

# Porta do Postgres no host (Docker). Mude se 5432 já estiver em uso (ex.: 5433).
# POSTGRES_HOST_PORT=5432

# Database (PostgreSQL local via Docker)
# User: postgres, Password: admin - configure via DATABASE_URL only, never hardcode.
# Em produção na VPS use 127.0.0.1 e senha forte (não "admin").
DATABASE_URL="postgresql://postgres:admin@localhost:5432/inout_central?schema=public"

# Google Sheets API (Service Account)
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets.readonly

# Meta Marketing API (dados META vêm somente da API, não das planilhas)
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=act_XXXXXXXX

# Google Ads API (OAuth - substitui/complementa dados de planilhas)
# O DEVELOPER_TOKEN é obtido em https://ads.google.com/aw/apicenter (conta gerente Google Ads)
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# customer_id por cliente em Conta (plataforma GOOGLE_ADS)

# Google Analytics 4 (Service Account - JSON completo como string)
# GOOGLE_ANALYTICS_CREDENTIALS={"type":"service_account",...}
# property_id por cliente em Conta (plataforma GOOGLE_ANALYTICS)

# Sync endpoint protection (cron job calls with this token)
# Obrigatório em produção se expuser /api/sync/* via HTTP.
# SYNC_CRON_TOKEN=

# Admin area protection
# Obrigatório em produção para /admin/*.
# ADMIN_SECRET=

# Upload de logos (opcional — na VPS deixe vazio; usa public/logos/)
# BLOB_READ_WRITE_TOKEN=
